   "source": [
    "Read Image \"image.jpeg\" and display it using OpenCV."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "86e13a98",
   "metadata": {},
   "outputs": [],
   "source": [
    "import cv2"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "21a8fe43",
   "metadata": {},
   "outputs": [],
   "source": [
    "img = cv2.imread(\"image.jpeg\")\n",
    "cv2.imshow(\"Image\", img)\n",
    "cv2.waitKey(0)\n",
    "cv2.destroyAllWindows()"
   ]
  }
